{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "preview": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/notifications",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/storage-reconcile",
      "schedule": "0 2 * * *"
    }
  ]
}
